#!/usr/bin/env bash

WORKFOLDER="$HOME/workfolder"
SKILLS_REPO="my-tools"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

_check_deps() {
    if ! command -v gh &>/dev/null; then
        echo -e "${RED}Error: 'gh' (GitHub CLI) is not installed.${NC}"
        echo "Install it with: sudo apt install gh && gh auth login"
        exit 1
    fi
}

_project_create() {
    local name="$1"
    if [[ -z "$name" ]]; then
        echo -e "${RED}Usage: project create <name>${NC}"
        exit 1
    fi

    _check_deps

    local dir="$WORKFOLDER/$name"

    if [[ -d "$dir" ]]; then
        echo -e "${RED}Directory '$dir' already exists.${NC}"
        exit 1
    fi

    echo -e "${BLUE}Creating project ${BOLD}$name${NC}${BLUE}...${NC}"
    mkdir -p "$dir"
    cd "$dir" || exit 1

    git init -q
    echo "# $name" > README.md
    git add README.md
    git commit -q -m "Initial commit"

    echo -e "${BLUE}Creating GitHub repository...${NC}"
    gh repo create "$name" --public --source=. --remote=origin --push

    echo -e "${GREEN}Project '$name' created and pushed to GitHub!${NC}"
    echo -e "${BLUE}Opening Claude Code in $dir...${NC}"

    cd "$dir" && exec claude --dangerously-skip-permissions
}

_ensure_skills_repo() {
    local skills_dir="$WORKFOLDER/$SKILLS_REPO"
    if [[ ! -d "$skills_dir" ]]; then
        local gh_user
        gh_user=$(gh api user -q .login 2>/dev/null)
        if [[ -n "$gh_user" ]]; then
            echo -e "${BLUE}Cloning skills repo (${gh_user}/${SKILLS_REPO})...${NC}"
            gh repo clone "$gh_user/$SKILLS_REPO" "$skills_dir" -- -q 2>/dev/null \
                && echo -e "${GREEN}Skills repo ready at $skills_dir${NC}" \
                || echo -e "${YELLOW}Skills repo not found on GitHub, skipping.${NC}"
        fi
    fi
}

_project_start() {
    _check_deps
    _ensure_skills_repo

    echo -e "${BLUE}Fetching your GitHub repositories...${NC}"

    local repos
    repos=$(gh repo list --limit 200 --json nameWithOwner -q '.[].nameWithOwner' 2>/dev/null)

    if [[ -z "$repos" ]]; then
        echo -e "${RED}No repositories found or not authenticated. Run: gh auth login${NC}"
        exit 1
    fi

    local selected
    if command -v fzf &>/dev/null; then
        selected=$(echo "$repos" | fzf \
            --prompt="  Select repo > " \
            --height=50% \
            --border=rounded \
            --header="GitHub Repositories" \
            --header-first \
            --color=header:bold)
    else
        echo ""
        local i=1
        local arr=()
        while IFS= read -r repo; do
            printf "  ${BLUE}%3d)${NC} %s\n" "$i" "$repo"
            arr+=("$repo")
            ((i++))
        done <<< "$repos"
        echo ""
        read -rp "Select number: " choice
        if [[ -z "${arr[$((choice-1))]}" ]]; then
            echo -e "${RED}Invalid selection.${NC}"
            exit 1
        fi
        selected="${arr[$((choice-1))]}"
    fi

    if [[ -z "$selected" ]]; then
        echo -e "${YELLOW}No repository selected.${NC}"
        exit 0
    fi

    local repo_name="${selected##*/}"
    local dir="$WORKFOLDER/$repo_name"

    if [[ -d "$dir" ]]; then
        echo -e "${YELLOW}Directory already exists, opening Claude there...${NC}"
    else
        echo -e "${BLUE}Cloning ${BOLD}$selected${NC}${BLUE}...${NC}"
        gh repo clone "$selected" "$dir" -- -q
        echo -e "${GREEN}Cloned to $dir${NC}"
    fi

    echo -e "${BLUE}Opening Claude Code in $dir...${NC}"

    cd "$dir" && exec claude --dangerously-skip-permissions
}

_project_exit() {
    local date_suffix
    date_suffix=$(date +"%d-%m-%Y")
    local branch="remaining work from $date_suffix"
    _check_deps

    echo -e "${BOLD}${BLUE}Saving all projects to GitHub...${NC}"

    # Repos whose work did NOT make it to GitHub. These are NEVER deleted.
    local failed_repos=()

    shopt -s nullglob
    local dirs=("$WORKFOLDER"/*/)

    for dir in "${dirs[@]}"; do
        [[ -d "$dir/.git" ]] || continue

        local repo_name
        repo_name=$(basename "$dir")

        echo ""
        echo -e "${BOLD}--- $repo_name ---${NC}"

        cd "$dir" || continue

        # Detect nested git repos
        local nested_gits
        nested_gits=$(find . -mindepth 2 -name ".git" -type d 2>/dev/null)
        if [[ -n "$nested_gits" ]]; then
            echo -e "  ${RED}AVISO: repos git aninhados detectados em '$repo_name':${NC}"
            while IFS= read -r nested; do
                local nested_dir="${nested%/.git}"
                echo -e "    ${YELLOW}→ $nested_dir${NC}"
            done <<< "$nested_gits"
            echo ""
            read -rp "  Remover os .git internos e salvar tudo? (y/N): " confirm
            if [[ "${confirm,,}" == "y" ]]; then
                while IFS= read -r nested; do
                    rm -rf "$nested"
                    echo -e "  ${GREEN}Removido: $nested${NC}"
                done <<< "$nested_gits"
            fi
        fi

        git add -A 2>/dev/null || true

        if ! git diff --cached --quiet 2>/dev/null; then
            git commit -q -m "work in progress - $date_suffix" 2>/dev/null || true
            echo -e "  Committed pending changes."
        else
            echo -e "  Nothing to commit."
        fi

        local current_branch
        current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

        if git push -q 2>/dev/null; then
            echo -e "  ${GREEN}Pushed '$current_branch' successfully.${NC}"
        else
            echo -e "  ${YELLOW}Push failed, saving to branch '${branch}'...${NC}"
            git checkout -q -b "$branch" 2>/dev/null || git checkout -q "$branch" 2>/dev/null || true
            if git push -q --set-upstream origin "$branch" 2>/dev/null; then
                echo -e "  ${GREEN}Saved to branch '${branch}'.${NC}"
            else
                echo -e "  ${RED}Could not push '$repo_name' to GitHub.${NC}"
                echo -e "  ${YELLOW}Keeping local folder safe — work was NOT deleted.${NC}"
                failed_repos+=("$repo_name")
            fi
        fi
    done

    echo ""
    echo -e "${BLUE}Cleaning workfolder...${NC}"

    # Only delete folders that were safely pushed. Anything that failed to
    # reach GitHub stays on disk so no work is ever lost.
    for dir in "$WORKFOLDER"/*/ "$WORKFOLDER"/*; do
        [[ -e "$dir" ]] || continue
        local entry
        entry=$(basename "$dir")
        [[ "$entry" == "CLAUDE.md" ]] && continue

        local skip=""
        for failed in "${failed_repos[@]}"; do
            if [[ "$entry" == "$failed" ]]; then
                skip="yes"
                break
            fi
        done

        if [[ -n "$skip" ]]; then
            echo -e "  ${YELLOW}Kept '$entry' (not on GitHub yet).${NC}"
        else
            rm -rf "$dir"
        fi
    done

    if (( ${#failed_repos[@]} > 0 )); then
        echo ""
        echo -e "${YELLOW}${BOLD}Atenção:${NC} ${YELLOW}${#failed_repos[@]} repo(s) não foram salvos no GitHub e foram mantidos localmente:${NC}"
        for failed in "${failed_repos[@]}"; do
            echo -e "  ${RED}→ $failed${NC}"
        done
        echo -e "${YELLOW}Resolva o push manualmente antes de rodar 'project exit' de novo.${NC}"
    else
        echo -e "${GREEN}${BOLD}Done! Workfolder is clean.${NC}"
    fi
}

case "${1:-}" in
    create)
        _project_create "${2:-}"
        ;;
    start)
        _project_start
        ;;
    exit)
        _project_exit
        ;;
    *)
        echo ""
        echo -e "  ${BOLD}project${NC} — manage your GitHub projects"
        echo ""
        echo -e "  ${GREEN}project create <name>${NC}"
        echo    "      Create a new project, push to GitHub, open Claude"
        echo ""
        echo -e "  ${GREEN}project start${NC}"
        echo    "      Select a GitHub repo, clone it, open Claude"
        echo ""
        echo -e "  ${GREEN}project exit${NC}"
        echo    "      Save all work to GitHub and clean workfolder"
        echo ""
        ;;
esac
